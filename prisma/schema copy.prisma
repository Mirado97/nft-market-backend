// Prisma Schema для GENESIS Protocol

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  walletAddress    String    @unique @db.VarChar(42)

  // Telegram привязка
  telegramId       BigInt?   @unique
  telegramUsername  String?   @db.VarChar(64)
  telegramLinkedAt DateTime?

  // Одноразовый nonce для привязки TG
  linkNonce        String?   @unique @db.VarChar(64)
  linkNonceExpiry  DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  nfts             Nft[]
}

model Nft {
  id            String    @id @default(cuid())
  tokenId       Int?
  txHash        String?   @db.VarChar(66)
  ipfsImageUri  String    @default("")
  ipfsMetaUri   String    @default("")
  status        NftStatus @default(PENDING)

  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])

  createdAt     DateTime  @default(now())
}

enum NftStatus {
  PENDING
  MINTING
  MINTED
  FAILED
}
