generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                @id @default(cuid())
  walletAddress    String?               @unique @db.VarChar(42)

  telegramId       BigInt?               @unique
  telegramUsername String?               @db.VarChar(64)
  telegramLinkedAt DateTime?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  nfts             Nft[]
  linkSessions     TelegramLinkSession[]
}

model TelegramLinkSession {
  id               String                @id @default(cuid())
  token            String                @unique @db.VarChar(128)
  type             LinkSessionType
  status           LinkSessionStatus     @default(PENDING)

  walletAddress    String?               @db.VarChar(42)
  telegramId       BigInt?
  telegramUsername String?               @db.VarChar(64)

  userId           String?
  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  expiresAt        DateTime
  confirmedAt      DateTime?
  consumedAt       DateTime?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@index([walletAddress])
  @@index([telegramId])
  @@index([userId])
}

model Nft {
  id           String    @id @default(cuid())
  tokenId      Int?
  txHash       String?   @db.VarChar(66)
  ipfsImageUri String    @default("")
  ipfsMetaUri  String    @default("")
  status       NftStatus @default(PENDING)

  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum NftStatus {
  PENDING
  MINTING
  MINTED
  FAILED
}

enum LinkSessionType {
  TELEGRAM_LINK
  DESKTOP_LOGIN
}

enum LinkSessionStatus {
  PENDING
  CONFIRMED
  CONSUMED
  EXPIRED
  CANCELLED
}
